rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the user is an admin (requires a 'role' field in user document)
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function roomDoc(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data;
    }

    function groupDoc(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }

    function isRoomParticipant(roomId) {
      return isAuthenticated() && request.auth.uid in roomDoc(roomId).participants;
    }

    function isGroupMember(groupId) {
      return isAuthenticated() && request.auth.uid in groupDoc(groupId).members;
    }

    function hotSpotChatDoc(chatId) {
      return get(/databases/$(database)/documents/hotSpotChats/$(chatId)).data;
    }

    function isHotSpotChatParticipant(chatId) {
      return isAuthenticated() && request.auth.uid in hotSpotChatDoc(chatId).participants;
    }

    // Rules for users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Prevent users from escalating their own privileges
      allow write: if isOwner(userId) && 
                    !request.resource.data.diff(resource.data).affectedKeys()
                    .hasAny(['role', 'isPremium', 'coins', 'level']);
      // Only admins can change roles/coins directly via Firestore
      allow update: if isAdmin();
    }

    // Rules for user_encounters (Crossing Paths)
    match /user_encounters/{userId} {
      match /history/{encounterId} {
        allow read: if isOwner(userId);
        allow write: if isAuthenticated(); // Both users involved can record
      }
    }

    // Rules for profile_visits
    match /profile_visits/{visitId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.visitedId || 
        request.auth.uid == resource.data.visitorId ||
        isAdmin()
      );
    }

    // Rules for userVibes collection
    match /userVibes/{vibeId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        (resource == null || resource.data.userId == request.auth.uid);
    }

    // Rules for calls collection
    match /calls/{callId} {
      allow read, update, delete: if isAuthenticated() && 
        (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.callerId;
    }

    // Rules for badWords collection
    match /badWords/{document} {
      allow read: if true;
      allow write: if isAdmin(); 
    }

    // Rules for private chat rooms
    match /rooms/{roomId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated()
                    && request.auth.uid in resource.data.participants
                    && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if isRoomParticipant(roomId);
        allow create: if isRoomParticipant(roomId)
                      && request.resource.data.uid == request.auth.uid;
        allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
      }
    }

    // Rules for groups
    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.members;
      allow update: if isAuthenticated()
                    && request.auth.uid in resource.data.members
                    && request.auth.uid in request.resource.data.members;

      match /messages/{messageId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId)
                      && request.resource.data.uid == request.auth.uid;
        allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
      }
    }
    
    // Rules for reports
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }
    
    match /flagged_content/{flagId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }
    
    match /transactions/{txId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.uid) || isAdmin());
      allow write: if false; // Only server (Admin SDK) can write
    }

    // HotSpot data (support both legacy 'hotSpots' and lowercase 'hotspots')
    match /hotSpots/{hotSpotId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /hotspots/{hotSpotId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /hotSpotInteractions/{interactionId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /eventInterests/{interestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /eventInvites/{inviteId} {
      allow read: if isAuthenticated() &&
        (resource.data.inviterId == request.auth.uid ||
         resource.data.inviteeId == request.auth.uid ||
         isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.inviterId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        (resource.data.inviterId == request.auth.uid ||
         resource.data.inviteeId == request.auth.uid ||
         isAdmin());
    }

    match /hotSpotChats/{chatId} {
      allow read: if isHotSpotChatParticipant(chatId);
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
      allow update: if isHotSpotChatParticipant(chatId);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isHotSpotChatParticipant(chatId);
        allow create: if isHotSpotChatParticipant(chatId) &&
          request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAuthenticated() &&
          (resource.data.senderId == request.auth.uid || isAdmin());
      }
    }

    match /hotSpotInvites/{inviteId} {
      allow read: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid ||
         isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid ||
         isAdmin());
    }

    match /meetupSessions/{sessionId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();
    }

    match /hotSpotMeetupHistory/{historyId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
  }
}

